rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isVerified() { return request.auth.token.email_verified == true; }

    // Phase 4: Drafting the "Fortress" Rules
    
    // User Profile Validation Helper
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 256 &&
             (data.get('displayName', '') is string && data.get('displayName', '').size() <= 128) &&
             (data.get('photoURL', '') is string && data.get('photoURL', '').size() <= 1024);
    }

    // Watchlist Item Validation Helper
    function isValidWatchlistItem(data) {
      return data.keys().hasAll(['id', 'title']) &&
             data.id is number &&
             data.title is string && data.title.size() <= 256 &&
             (data.get('poster_path', '') is string && data.get('poster_path', '').size() <= 1024) &&
             (data.get('addedAt', request.time) == request.time);
    }

    // Rating Validation Helper
    function isValidRating(data) {
      return data.keys().hasAll(['movieId', 'rating']) &&
             data.movieId is number &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             (data.get('updatedAt', request.time) == request.time);
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming()) && isVerified();
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    (
                      incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL'])
                    ) &&
                    isVerified();

      match /watchlist/{movieId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidWatchlistItem(incoming()) && isVerified() && isValidId(movieId);
        allow delete: if isOwner(userId);
      }

      match /ratings/{movieId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidRating(incoming()) && isVerified() && isValidId(movieId);
        allow update: if isOwner(userId) && isValidRating(incoming()) && isVerified() && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['rating', 'updatedAt']);
        allow delete: if isOwner(userId);
      }
    }
  }
}
